---
import Layout from "../layouts/Layout.astro";
import Banner300x250 from "../components/Banner300x250.astro";
import { getCollection } from "astro:content";

const allProducts = await getCollection("products");

const categories = [
  "All",
  "Consoles",
  "Power Solutions",
  "Storage",
  "Docks & Hubs",
  "Peripherals",
];

const categoryLabels: Record<string, string> = {
  Consoles: "CONSOLE",
  "Power Solutions": "POWER SOLUTION",
  Storage: "STORAGE",
  "Docks & Hubs": "DOCK & HUB",
  Peripherals: "PERIPHERAL",
};

const subCategoryLabels: Record<string, string> = {
  "Baseus 65W GaN3 Pro": "WALL CHARGER",
  "Anker Nano II 65W": "WALL CHARGER",
  "UGREEN Nexode 100W": "WALL CHARGER",
  "INIU 100W 25000mAh": "POWER BANK",
  "Anker 737 Power Bank 24000mAh": "POWER BANK",
  "Shargeek Storm 2": "POWER BANK",
  "JSAUX 100W Right-Angle Cable": "CABLE",
  "Samsung 990 EVO Plus 1TB": "SSD",
  "Samsung 990 EVO Plus 2TB": "SSD",
  "WD Black SN770M 1TB": "SSD",
  "Sabrent Rocket 2230 1TB": "SSD",
  "Samsung Pro Ultimate 1TB": "MICROSD",
  "SanDisk Extreme 1TB": "MICROSD",
  "Lexar Play 1TB": "MICROSD",
  "Samsung T7 Shield 1TB": "EXTERNAL SSD",
  "SanDisk Extreme 512GB": "MICROSD",
  "Samsung 990 EVO Plus 4TB": "SSD",
  "JSAUX RGB Docking Station": "DOCK",
  "Steam Deck Official Dock": "DOCK",
  "Anker 6-in-1 USB-C Hub": "PORTABLE HUB",
  "Syntech 6-in-1 Docking Station": "DOCK",
  "UGREEN Revodok Pro": "DOCK",
  "Baseus 17-in-1 Docking Station": "DOCK",
  "JSAUX HB0603 6-in-1 Hub": "HUB",
  "ivoler 6-in-1 Dock": "DOCK",
  "Dell D6000 Universal Dock": "DOCK",
  "CalDigit TS4 Thunderbolt 4 Dock": "DOCK",
  "JSAUX Anti-Glare Screen Protector": "SCREEN PROTECTOR",
  "amFilm OneTouch Glass": "SCREEN PROTECTOR",
  "Skull & Co. GripCase": "CASE & GRIP",
  "JSAUX ModCase": "CASE & GRIP",
  "GuliKit Hall Effect Joystick": "JOYSTICK REPLACEMENT",
  "8BitDo Ultimate 2C": "EXTERNAL CONTROLLER",
  "JSVER Carrying Case": "CARRYING CASE",
  "Killswitch Case & Grip": "CASE & GRIP",
  "DeltaHub Carpio 2.0": "ERGONOMIC ACCESSORY",
  "Steam Controller 2": "EXTERNAL CONTROLLER",
  "Xbox Wireless Controller": "EXTERNAL CONTROLLER",
  "PS5 DualSense Edge": "EXTERNAL CONTROLLER",
  "NZXT Capsule USB Mic": "AUDIO ACCESSORY",
};
---

<Layout title="Product Comparison | Hand Held Mastery" active="compare">
  <div class="max-w-[1280px] mx-auto px-4 py-10">
    <div class="mb-10 text-center">
      <h1 class="text-3xl font-extrabold text-text-primary sm:text-4xl">Product Comparison</h1>
      <p class="mt-3 text-lg text-text-muted">Compare {allProducts.length}+ handheld gaming products.</p>
    </div>

    <!-- Category Filters -->
    <div class="flex flex-wrap gap-2 mb-4" id="category-filters">
      {categories.map((cat) => (
        <button
          class="filter-btn px-4 py-2 text-sm font-medium border border-border-dark bg-card-dark text-text-muted hover:text-text-primary hover:bg-[#1E293B] transition-all"
          data-category={cat}
        >
          {cat} ({cat === "All" ? allProducts.length : allProducts.filter((p) => p.data.category === cat).length})
        </button>
      ))}
    </div>

    <Banner300x250 />

    <!-- Product Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="product-grid">
      {allProducts.map((p) => (
        <a
          href={`/compare/${p.data.slug}`}
          class="product-card block bg-card-dark border border-border-dark p-5 hover:border-accent-purple transition-all hover:-translate-y-0.5"
          data-category={p.data.category}
        >
          <span class="text-xs font-semibold tracking-wider uppercase text-accent-cyan-light mb-2 block">
            {subCategoryLabels[p.data.name] || categoryLabels[p.data.category] || p.data.category.toUpperCase()}
          </span>
          <h3 class="text-base font-semibold text-text-primary mb-2">{p.data.name}</h3>
          <p class="text-xl font-bold text-text-primary mb-2">${p.data.price}</p>
          <p class="text-sm text-text-dim leading-relaxed mb-3">{p.data.description}</p>
          <div class="flex flex-wrap gap-2">
            {p.data.tags.map((tag) => (
              <span class="text-xs px-2 py-1 bg-[#0F172A] text-text-muted">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </div>

  <script is:inline>
    // Client-side category filtering
    const buttons = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.product-card');
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const cat = btn.dataset.category;
        buttons.forEach((b) => {
          b.style.backgroundColor = b === btn ? '#7C3AED' : '#111827';
          b.style.color = b === btn ? '#FFFFFF' : '#94A3B8';
          b.style.borderColor = b === btn ? '#7C3AED' : '#1E293B';
        });
        cards.forEach((card) => {
          card.style.display = cat === 'All' || card.dataset.category === cat ? 'block' : 'none';
        });
      });
    });
    // Set "All" as active initially
    if (buttons[0]) {
      buttons[0].style.backgroundColor = '#7C3AED';
      buttons[0].style.color = '#FFFFFF';
      buttons[0].style.borderColor = '#7C3AED';
    }
  </script>
</Layout>
