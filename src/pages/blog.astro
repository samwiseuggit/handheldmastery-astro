---
import Layout from "../layouts/Layout.astro";
import Banner300x250 from "../components/Banner300x250.astro";
import { getCollection } from "astro:content";

const allArticles = await getCollection("articles");
allArticles.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

const categoryTabs = ["All", "Versus", "How-To", "Guides", "Blog"];

const getArticleCategory = (cat: string) => {
  if (cat.includes("vs")) return "Versus";
  if (cat.includes("How-To")) return "How-To";
  if (cat.includes("Guide")) return "Guides";
  return "Blog";
};
---

<Layout title="Blog | Hand Held Mastery" active="blog">
  <div class="max-w-[1280px] mx-auto px-4 py-10">
    <div class="mb-10 text-center">
      <h1 class="text-3xl font-extrabold text-text-primary sm:text-4xl">Latest Articles</h1>
      <p class="mt-3 text-lg text-text-muted">{allArticles.length}+ guides, comparisons, and how-tos for handheld gaming.</p>
    </div>

    <div class="flex justify-center mb-6">
      <Banner300x250 />
    </div>

    <!-- Category Tabs -->
    <div class="flex flex-wrap gap-2 mb-8">
      {categoryTabs.map((tab) => (
        <button
          class="cat-tab px-4 py-2 text-sm font-medium border border-border-dark bg-card-dark text-text-muted hover:text-text-primary hover:bg-[#1E293B] transition-all"
          data-tab={tab}
        >
          {tab}
        </button>
      ))}
    </div>

    <!-- Article Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" id="article-grid">
      {allArticles.map((article) => (
        <a
          href={`/articles/${article.slug}`}
          class="article-card block bg-card-dark border border-border-dark p-5 hover:border-accent-purple transition-all"
          data-tab={getArticleCategory(article.data.category)}
        >
          <span class="inline-block px-2 py-0.5 text-xs bg-[#0F172A] text-accent-cyan-light mb-2">
            {article.data.category}
          </span>
          <h3 class="text-sm font-semibold text-text-primary mb-2 line-clamp-2">{article.data.title}</h3>
          <p class="text-xs text-text-dim">{article.data.date} &middot; {article.data.readTime}</p>
        </a>
      ))}
    </div>
  </div>

  <script is:inline>
    const tabs = document.querySelectorAll('.cat-tab');
    const cards = document.querySelectorAll('.article-card');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const t = tab.dataset.tab;
        tabs.forEach((btn) => {
          btn.style.backgroundColor = btn === tab ? '#7C3AED' : '#111827';
          btn.style.color = btn === tab ? '#FFFFFF' : '#94A3B8';
          btn.style.borderColor = btn === tab ? '#7C3AED' : '#1E293B';
        });
        cards.forEach((card) => {
          card.style.display = t === 'All' || card.dataset.tab === t ? 'block' : 'none';
        });
      });
    });
    if (tabs[0]) {
      tabs[0].style.backgroundColor = '#7C3AED';
      tabs[0].style.color = '#FFFFFF';
      tabs[0].style.borderColor = '#7C3AED';
    }
  </script>
</Layout>
