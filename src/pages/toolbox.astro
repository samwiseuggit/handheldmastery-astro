---
import Layout from "../layouts/Layout.astro";
import Banner300x250 from "../components/Banner300x250.astro";

const tools = [
  { name: "EmuDeck", desc: "All-in-one emulation setup for Steam Deck and Windows handhelds. The easiest way to play retro games on your handheld.", category: "Essential", price: "Free", link: "https://www.emudeck.com/" },
  { name: "Decky Loader", desc: "Plugin system for Steam Deck. Install plugins for performance monitoring, custom themes, and power tweaks.", category: "Essential", price: "Free", link: "https://github.com/SteamDeckHomebrew/decky-loader" },
  { name: "Handheld Companion", desc: "Motion controls, remapping, and TDP control for Windows handhelds. Essential for non-Steam Deck devices.", category: "Recommended", price: "Free", link: "https://handheldcompanion.com/" },
  { name: "Lossless Scaling", desc: "Frame generation for any game using LSFG. Double your FPS on AAA titles with minimal quality loss.", category: "Worth It", price: "$7", link: "https://store.steampowered.com/app/993090" },
  { name: "Moonlight", desc: "Low-latency game streaming from your PC to your handheld. Play your full PC library anywhere at home.", category: "Free", price: "Free", link: "https://moonlight-stream.org/" },
  { name: "ProtonDB", desc: "Community database of game compatibility reports for Linux/SteamOS. Check if your games work before buying.", category: "Essential", price: "Free", link: "https://www.protondb.com/" },
];

const categoryTabs = ["All", "Essential", "Recommended", "Worth It", "Free"];
---

<Layout title="Gamer's Toolbox | Hand Held Mastery" active="toolbox">
  <div class="max-w-[1280px] mx-auto px-4 py-10">
    <div class="mb-10 text-center">
      <h1 class="text-3xl font-extrabold text-text-primary sm:text-4xl">Gamer's Toolbox</h1>
      <p class="mt-3 text-lg text-text-muted">Essential software for handheld PC gaming.</p>
    </div>

    <div class="flex justify-center mb-6">
      <Banner300x250 />
    </div>

    <div class="flex flex-wrap gap-2 mb-8">
      {categoryTabs.map((tab) => (
        <button class="tool-tab px-4 py-2 text-sm font-medium border border-border-dark bg-card-dark text-text-muted hover:text-text-primary hover:bg-[#1E293B] transition-all" data-tab={tab}>
          {tab}
        </button>
      ))}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="tool-grid">
      {tools.map((tool) => (
        <div class="tool-card bg-card-dark border border-border-dark p-5" data-tab={tool.category}>
          <div class="flex items-center justify-between mb-2">
            <h3 class="text-base font-semibold text-text-primary">{tool.name}</h3>
            <span class="text-xs px-2 py-0.5 bg-[#0F172A] text-accent-cyan-light">{tool.category}</span>
          </div>
          <p class="text-sm text-text-dim leading-relaxed mb-3">{tool.desc}</p>
          <div class="flex items-center justify-between">
            <span class="text-sm font-semibold text-text-primary">{tool.price}</span>
            <a href={tool.link} target="_blank" rel="noopener noreferrer" class="text-accent-cyan text-sm hover:underline">Visit &rarr;</a>
          </div>
        </div>
      ))}
    </div>
  </div>

  <script is:inline>
    const tabs = document.querySelectorAll('.tool-tab');
    const cards = document.querySelectorAll('.tool-card');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const t = tab.dataset.tab;
        tabs.forEach((b) => { b.style.backgroundColor = b === tab ? '#7C3AED' : '#111827'; b.style.color = b === tab ? '#FFFFFF' : '#94A3B8'; b.style.borderColor = b === tab ? '#7C3AED' : '#1E293B'; });
        cards.forEach((c) => { c.style.display = t === 'All' || c.dataset.tab === t ? 'block' : 'none'; });
      });
    });
    if (tabs[0]) { tabs[0].style.backgroundColor = '#7C3AED'; tabs[0].style.color = '#FFFFFF'; tabs[0].style.borderColor = '#7C3AED'; }
  </script>
</Layout>
