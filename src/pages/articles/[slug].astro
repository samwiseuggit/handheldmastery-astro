---
import Layout from "../../layouts/Layout.astro";
import Banner300x250 from "../../components/Banner300x250.astro";
import { getCollection, getEntry } from "astro:content";
import { render } from "astro:content";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

// Get 3 random related articles
const allArticles = await getCollection("articles");
const related = allArticles
  .filter((a) => a.slug !== article.slug)
  .sort(() => Math.random() - 0.5)
  .slice(0, 3);
---

<Layout title={`${article.data.title} | Hand Held Mastery`} description={article.data.description} active="blog">
  <div class="max-w-[1100px] mx-auto px-4 pt-5 pb-16">
    <!-- Breadcrumb -->
    <nav class="text-sm text-text-dim mb-6">
      <a href="/" class="text-text-muted hover:text-accent-cyan">Home</a>
      <span class="mx-2 text-text-faint">&rsaquo;</span>
      <a href="/blog" class="text-text-muted hover:text-accent-cyan">Blog</a>
      <span class="mx-2 text-text-faint">&rsaquo;</span>
      <span>{article.data.title}</span>
    </nav>

    <!-- Article Header -->
    <div class="mb-8">
      <span class="inline-block px-3 py-1 bg-[#0F172A] text-accent-cyan-light text-xs font-semibold uppercase tracking-wider mb-3">
        {article.data.category}
      </span>
      <div class="flex items-center gap-4 text-sm text-text-dim mb-4">
        <span>{article.data.date}</span>
        <span>&middot;</span>
        <span>{article.data.readTime}</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold text-text-primary mb-4">{article.data.title}</h1>
      <div class="flex flex-wrap gap-2">
        {article.data.tags.map((tag) => (
          <span class="text-xs px-2 py-1 bg-[#0F172A] text-text-muted">{tag}</span>
        ))}
      </div>
    </div>

    <Banner300x250 />

    <!-- Article Body -->
    <article class="prose-custom mb-12">
      <Content />
    </article>

    <!-- CTA -->
    <div class="bg-gradient-to-br from-[rgba(109,40,217,0.15)] to-[rgba(8,145,178,0.15)] border border-border-dark p-8 text-center mb-12">
      <h3 class="text-lg font-bold text-text-primary mb-2">Compare products mentioned in this article</h3>
      <p class="text-text-muted mb-5">Browse 50+ handheld gaming products with real-time pricing and specs.</p>
      <a href="/compare" class="inline-flex items-center gap-2 bg-accent-purple text-white font-semibold px-6 py-3 hover:bg-accent-purple-hover transition-colors">
        Go to Comparison &rarr;
      </a>
    </div>

    <!-- Related Articles -->
    <div class="mb-12">
      <h3 class="text-lg font-bold text-text-primary mb-4">Related Articles</h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {related.map((a) => (
          <a href={`/articles/${a.slug}`} class="block bg-card-dark border border-border-dark p-5 hover:border-accent-purple transition-all hover:-translate-y-0.5">
            <div class="text-sm font-semibold text-text-primary mb-2 line-clamp-2">{a.data.title}</div>
            <div class="text-xs text-text-dim">Read more &rarr;</div>
          </a>
        ))}
      </div>
    </div>
  </div>

  <style>
    .prose-custom :global(h2) { font-size: 1.5rem; font-weight: 700; margin-top: 2.5rem; margin-bottom: 0.875rem; padding-bottom: 0.5rem; border-bottom: 1px solid #1E293B; color: #F8FAFC; }
    .prose-custom :global(h3) { font-size: 1.25rem; font-weight: 600; margin-top: 1.75rem; margin-bottom: 0.625rem; color: #F1F5F9; }
    .prose-custom :global(h4) { font-size: 1.1rem; font-weight: 600; margin-top: 1.25rem; margin-bottom: 0.5rem; color: #CBD5E1; }
    .prose-custom :global(p) { margin-bottom: 1rem; color: #CBD5E1; line-height: 1.75; }
    .prose-custom :global(ul), .prose-custom :global(ol) { margin-bottom: 1rem; padding-left: 1.5rem; }
    .prose-custom :global(li) { margin-bottom: 0.375rem; color: #CBD5E1; }
    .prose-custom :global(strong) { color: #F8FAFC; }
    .prose-custom :global(table) { width: 100%; border-collapse: collapse; margin: 1.25rem 0; font-size: 0.875rem; }
    .prose-custom :global(th) { background: #0F172A; padding: 0.625rem 0.75rem; text-align: left; font-weight: 600; color: #94A3B8; border-bottom: 2px solid #334155; }
    .prose-custom :global(td) { padding: 0.5rem 0.75rem; border-bottom: 1px solid #1E293B; color: #CBD5E1; }
    .prose-custom :global(blockquote) { border-left: 3px solid #38BDF8; padding-left: 1rem; margin: 1.25rem 0; color: #94A3B8; font-style: italic; }
    .prose-custom :global(a) { color: #38BDF8; }
    .prose-custom :global(a:hover) { text-decoration: underline; }
    .prose-custom :global(hr) { border: none; border-top: 1px solid #1E293B; margin: 2rem 0; }
  </style>
</Layout>
