---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const products = await getCollection("products");
const articles = await getCollection("articles");

const featuredConsoles = products
  .filter((p) => p.data.category === "Consoles")
  .slice(0, 5);

const latestArticles = articles
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
  .slice(0, 6);

// Star rating helper
function renderStars(rating: number) {
  const full = Math.floor(rating);
  const half = rating % 1 >= 0.3 ? 1 : 0;
  const empty = 5 - full - half;
  return "★".repeat(full) + (half ? "½" : "") + "☆".repeat(empty);
}

const consoleLabels: Record<string, string> = {
  "steam-deck-oled": "OLED HANDHELD",
  "asus-rog-ally-x": "FLAGSHIP WINDOWS",
  "lenovo-legion-go-2": "BIG SCREEN PREMIUM",
  "lenovo-legion-go-s": "STEAMOS ALTERNATIVE",
  "msi-claw-8-ai": "AI-POWERED",
  "onexplayer-g1": "ULTIMATE 2-IN-1",
  "zotac-zone": "COMPACT POWER",
};

const consoleShortDesc: Record<string, string> = {
  "steam-deck-oled-512gb": "Best value, best ergonomics,...",
  "steam-deck-oled-1tb": "Best value with room for large...",
  "asus-rog-ally-x": "Best Windows performance,...",
  "lenovo-legion-go-2": "Biggest OLED screen,...",
  "lenovo-legion-go-s": "SteamOS with bigger screen...",
  "msi-claw-8-ai": "Intel-powered Windows handh...",
  "onexplayer-g1": "Ultimate 2-in-1 handheld...",
  "zotac-zone": "Compact AMD-powered handh...",
};

const categories = [
  { name: "Consoles", count: products.filter((p) => p.data.category === "Consoles").length, slug: "Consoles" },
  { name: "Power Solutions", count: products.filter((p) => p.data.category === "Power Solutions").length, slug: "Power Solutions" },
  { name: "Storage", count: products.filter((p) => p.data.category === "Storage").length, slug: "Storage" },
  { name: "Docks & Hubs", count: products.filter((p) => p.data.category === "Docks & Hubs").length, slug: "Docks & Hubs" },
  { name: "Peripherals", count: products.filter((p) => p.data.category === "Peripherals").length, slug: "Peripherals" },
];

const tools = [
  { name: "EmuDeck", desc: "All-in-one emulation setup for Steam Deck and Windows handhelds", price: "Free", link: "https://www.emudeck.com/" },
  { name: "Decky Loader", desc: "Plugin loader for Steam Deck with 50+ community plugins", price: "Free", link: "https://github.com/SteamDeckHomebrew/decky-loader" },
  { name: "ProtonDB", desc: "Community game compatibility database for Linux/SteamOS", price: "Free", link: "https://www.protondb.com/" },
  { name: "Handheld Companion", desc: "TDP control, fan curves, and performance overlay for Windows handhelds", price: "Free", link: "https://handheldcompanion.com/" },
  { name: "Lossless Scaling", desc: "AI frame generation tool — double your FPS for $7", price: "$6.99", link: "https://store.steampowered.com/app/993090" },
  { name: "Moonlight", desc: "Open-source NVIDIA GameStream client for remote play", price: "Free", link: "https://moonlight-stream.org/" },
];

const articleShortDescs: Record<string, string> = {
  "state-of-handheld-gaming-2026": "Why consoles are killing gaming laptops.",
  "steam-deck-oled-vs-rog-ally-x": "The heavyweight battle — $549 vs $999.",
  "how-to-install-emudeck": "The easiest way to set up retro emulation.",
  "best-budget-handhelds-under-400": "High performance for under $400.",
  "ultimate-windows-11-debloat-guide": "Speed up your ROG Ally in 10 minutes.",
  "z2-extreme-vs-intel-core-ultra-200v": "The 2026 chip-set showdown.",
};
---

<Layout title="Hand Held Mastery | Handheld PC Gaming Console Reviews" active="home">
  <div class="max-w-[1200px] mx-auto px-4 py-10">

    <!-- Hero -->
    <div class="py-10 text-center">
      <h1 class="mb-3">
        <span class="block text-4xl sm:text-5xl font-bold bg-gradient-to-r from-accent-purple via-[#A78BFA] to-accent-cyan bg-clip-text text-transparent">
          Hand Held
        </span>
        <span class="block text-4xl sm:text-5xl font-extrabold text-text-primary mt-1">
          Mastery
        </span>
      </h1>
      <p class="text-text-muted text-base max-w-xl mx-auto mb-8">
        The definitive technical resource for handheld gaming consoles,<br class="hidden sm:block" />
        accessories, and optimization. 50+ products and 30 in-depth articles.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a
          href="/compare"
          class="inline-flex items-center gap-2 bg-accent-purple hover:bg-accent-purple-hover text-white font-semibold px-6 py-2.5 text-sm transition-colors"
        >
          Compare Products <span>→</span>
        </a>
        <a
          href="/blog"
          class="inline-flex items-center gap-2 bg-card-dark border border-border-dark hover:border-accent-purple text-text-muted hover:text-text-primary font-medium px-6 py-2.5 text-sm transition-colors"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
          Read 30 Articles
        </a>
      </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-14">
      <div class="bg-card-dark border border-border-dark p-5 text-center">
        <svg class="w-6 h-6 mx-auto mb-2 text-accent-purple" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="4" width="12" height="16" rx="2"/><path d="M12 8v4"/><circle cx="12" cy="15" r="1"/></svg>
        <div class="text-2xl font-bold text-text-primary">50+</div>
        <div class="text-sm text-text-muted">Products</div>
      </div>
      <div class="bg-card-dark border border-border-dark p-5 text-center">
        <svg class="w-6 h-6 mx-auto mb-2 text-accent-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
        <div class="text-2xl font-bold text-text-primary">30</div>
        <div class="text-sm text-text-muted">Articles</div>
      </div>
      <div class="bg-card-dark border border-border-dark p-5 text-center">
        <svg class="w-6 h-6 mx-auto mb-2 text-accent-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
        <div class="text-2xl font-bold text-text-primary">10+</div>
        <div class="text-sm text-text-muted">Software Tools</div>
      </div>
      <div class="bg-card-dark border border-border-dark p-5 text-center">
        <svg class="w-6 h-6 mx-auto mb-2 text-star-yellow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        <div class="text-2xl font-bold text-text-primary">5</div>
        <div class="text-sm text-text-muted">Retailer Networks</div>
      </div>
    </div>

    <!-- Featured Consoles (2026) -->
    <h2 class="text-lg font-bold text-text-primary mb-4">Featured Consoles (2026)</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3 mb-14">
      {featuredConsoles.map((p) => (
        <a
          href={`/compare/${p.data.slug}`}
          class="block bg-card-dark border border-border-dark p-4 hover:border-accent-purple transition-all hover:-translate-y-0.5"
        >
          <span class="text-[10px] font-semibold tracking-wider uppercase text-accent-cyan-light mb-1.5 block">
            {consoleLabels[p.data.slug] || "CONSOLE"}
          </span>
          <h3 class="text-sm font-semibold text-text-primary mb-1.5 leading-tight">{p.data.name}</h3>
          <div class="text-star-yellow text-xs mb-1.5">
            {renderStars(p.data.rating)} <span class="text-text-dim">{p.data.rating}</span>
          </div>
          <p class="text-base font-bold text-text-primary mb-1.5">${p.data.price}</p>
          <p class="text-xs text-text-dim leading-relaxed">
            {consoleShortDesc[p.data.slug] || p.data.description.substring(0, 45) + "..."}
          </p>
        </a>
      ))}
    </div>

    <!-- Browse by Category -->
    <h2 class="text-lg font-bold text-text-primary mb-4">Browse by Category</h2>
    <div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-14">
      {categories.map((cat, i) => (
        <a
          href={`/compare?cat=${encodeURIComponent(cat.slug)}`}
          class="bg-card-dark border border-border-dark p-5 text-center hover:border-accent-purple transition-all group"
        >
          <div class={`w-10 h-10 mx-auto mb-3 rounded-full flex items-center justify-center ${["bg-[#1E293B] text-accent-purple", "bg-[#1E293B] text-accent-cyan", "bg-[#1E293B] text-accent-cyan-light", "bg-[#1E293B] text-accent-purple", "bg-[#1E293B] text-accent-cyan"][i]}`}>
            {i === 0 && <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="4" width="12" height="16" rx="2"/><path d="M12 8v4"/><circle cx="12" cy="15" r="1"/></svg>}
            {i === 1 && <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>}
            {i === 2 && <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M8 12h8"/><path d="M12 8v8"/></svg>}
            {i === 3 && <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>}
            {i === 4 && <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v4"/><path d="M12 18v4"/><path d="M4.93 4.93l2.83 2.83"/><path d="M16.24 16.24l2.83 2.83"/><path d="M2 12h4"/><path d="M18 12h4"/><path d="M4.93 19.07l2.83-2.83"/><path d="M16.24 7.76l2.83-2.83"/></svg>}
          </div>
          <h3 class="text-sm font-semibold text-text-primary">{cat.name}</h3>
          <p class="text-xs text-text-dim mt-1">{cat.count} products</p>
        </a>
      ))}
    </div>

    <!-- Latest Articles -->
    <h2 class="text-lg font-bold text-text-primary mb-4">Latest Articles</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-6">
      {latestArticles.map((article) => (
        <a
          href={`/articles/${article.slug}`}
          class="block bg-card-dark border border-border-dark p-5 hover:border-accent-purple transition-all group"
        >
          <h3 class="text-sm font-semibold text-text-primary mb-2 line-clamp-1">{article.data.title}</h3>
          <p class="text-xs text-text-dim mb-3 line-clamp-1">
            {articleShortDescs[article.slug] || article.data.description.substring(0, 60) + "..."}
          </p>
          <span class="text-xs text-accent-cyan-light group-hover:text-accent-cyan transition-colors">
            Read article →
          </span>
        </a>
      ))}
    </div>
    <div class="text-center mb-14">
      <a href="/blog" class="text-sm text-accent-cyan-light hover:text-accent-cyan transition-colors">
        View all 30 articles →
      </a>
    </div>

    <!-- Gamer's Toolbox -->
    <h2 class="text-lg font-bold text-text-primary mb-4">Gamer's Toolbox</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-6">
      {tools.map((tool) => (
        <a
          href={tool.link}
          target="_blank"
          rel="noopener noreferrer"
          class="block bg-card-dark border border-border-dark p-5 hover:border-accent-purple transition-all"
        >
          <div class="flex items-start justify-between mb-2">
            <h4 class="text-sm font-semibold text-text-primary">{tool.name}</h4>
            <span class={`text-[10px] px-2 py-0.5 rounded-full ${tool.price === "Free" ? "bg-[#0F2E1F] text-success-green" : "bg-[#2E1F0F] text-star-yellow"}`}>
              {tool.price}
            </span>
          </div>
          <p class="text-xs text-text-dim leading-relaxed">{tool.desc}</p>
        </a>
      ))}
    </div>
    <div class="text-center mb-14">
      <a href="/toolbox" class="text-sm text-accent-cyan-light hover:text-accent-cyan transition-colors">
        View all tools →
      </a>
    </div>

    <!-- CTA -->
    <div class="text-center py-14 px-6 rounded-lg" style="background: linear-gradient(135deg, rgba(109,40,217,0.2) 0%, rgba(8,145,178,0.15) 100%); border: 1px solid rgba(124,58,237,0.3);">
      <h2 class="text-2xl font-bold text-text-primary mb-3">Ready to master your handheld setup?</h2>
      <p class="text-text-muted text-sm max-w-lg mx-auto mb-6">
        Compare all 50+ products side-by-side with real-time pricing, technical specs, and honest recommendations.
      </p>
      <a
        href="/compare"
        class="inline-flex items-center gap-2 bg-accent-purple hover:bg-accent-purple-hover text-white font-semibold px-6 py-2.5 text-sm transition-colors"
      >
        Start Comparing <span>→</span>
      </a>
    </div>

  </div>
</Layout>
