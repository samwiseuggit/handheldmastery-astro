---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const BRAND_LINKS: Record<string, string> = {
  "Steam Deck": "https://store.steampowered.com/steamdeck",
  "ASUS": "https://shop.asus.com",
  "Lenovo": "https://www.lenovo.com",
  "MSI": "https://us.msi.com",
  "Zotac": "https://www.zotac.com",
  "OneXPlayer": "https://www.onexplayer.com",
  "Samsung": "https://www.samsung.com",
  "Anker": "https://www.anker.com",
  "JSAUX": "https://www.jsaux.com",
  "Baseus": "https://www.baseus.com",
  "UGREEN": "https://www.ugreen.com",
  "SanDisk": "https://www.sandisk.com",
  "8BitDo": "https://www.8bitdo.com",
  "Xbox": "https://www.xbox.com",
  "PS5": "https://www.playstation.com",
  "NZXT": "https://www.nzxt.com",
  "GuliKit": "https://www.gulikit.com",
  "INIU": "https://www.iniu.com",
  "WD": "https://www.westerndigital.com",
  "Sabrent": "https://www.sabrent.com",
  "Lexar": "https://www.lexar.com",
  "Syntech": "https://www.syntechtech.com",
  "ivoler": "https://www.ivoler.com",
  "Dell": "https://www.dell.com",
  "CalDigit": "https://www.caldigit.com",
  "Skull & Co.": "https://www.skullnco.com",
  "amFilm": "https://www.amfilm.com",
  "JSVER": "https://www.jsver.com",
  "Killswitch": "https://www.killswitch.com",
  "DeltaHub": "https://deltahub.io",
  "Shargeek": "https://www.shargeek.com",
  "Steam Controller": "https://store.steampowered.com",
};

const CATEGORY_LABELS: Record<string, string> = {
  Consoles: "Handheld Console",
  "Power Solutions": "Power Solution",
  Storage: "Storage",
  "Docks & Hubs": "Dock & Hub",
  Peripherals: "Peripheral",
};

export async function getStaticPaths() {
  const products = await getCollection("products");
  return products.map((product) => ({
    params: { slug: product.data.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const p = product.data;

const stars = "\u2605".repeat(Math.floor(p.rating)) + (p.rating % 1 >= 0.3 ? "\u00BD" : "") + "\u2606".repeat(5 - Math.floor(p.rating) - (p.rating % 1 >= 0.3 ? 1 : 0));

const brandKey = Object.keys(BRAND_LINKS).find((k) => p.name.includes(k));
const brandLink = brandKey ? BRAND_LINKS[brandKey] : null;
const badge = CATEGORY_LABELS[p.category] || p.category;
---

<Layout title={`${p.name} - Review, Specs & Price | Hand Held Mastery`} description={`Complete ${p.name} review with specs, pricing at $${p.price}, and where to buy.`} active="compare">
  <div class="max-w-[1100px] mx-auto px-4 pt-5 pb-16">
    <!-- Breadcrumb -->
    <nav class="text-sm text-text-dim mb-6">
      <a href="/" class="text-text-muted hover:text-accent-cyan">Home</a>
      <span class="mx-2 text-text-faint">&rsaquo;</span>
      <a href="/compare" class="text-text-muted hover:text-accent-cyan">Compare</a>
      <span class="mx-2 text-text-faint">&rsaquo;</span>
      <span>{p.name}</span>
    </nav>

    <!-- Product Image Placeholder -->
    <div class="w-full h-[220px] rounded-lg mb-6 flex items-center justify-center" style="background: linear-gradient(135deg, #1E293B, #334155);">
      <div class="text-center">
        <div class="text-5xl mb-2">&#127918;</div>
        <span class="text-sm text-text-muted uppercase tracking-wider font-semibold">{badge}</span>
      </div>
    </div>

    <!-- Product Header -->
    <div class="mb-8">
      <span class="inline-block px-3 py-1 bg-[#0F172A] text-accent-cyan-light text-xs font-semibold uppercase tracking-wider mb-3">
        {badge}
      </span>
      <h1 class="text-3xl sm:text-4xl font-extrabold text-text-primary mb-2">{p.name}</h1>
      <div class="text-star-yellow text-sm mb-2">{stars} {p.rating}/5.0</div>
      <div class="text-2xl font-extrabold text-text-primary mb-2">${p.price}</div>
      <p class="text-text-dim mb-4">{p.description}</p>
      <div class="flex flex-wrap gap-2">
        {p.tags.map((tag) => (
          <span class="text-xs px-2 py-1 bg-[#0F172A] text-text-muted">{tag}</span>
        ))}
      </div>
    </div>

    <!-- Specs Table (consoles only) -->
    {p.specs && p.specs.length > 0 && (
      <div class="mb-8">
        <h2 class="text-xl font-bold text-text-primary mb-4 pb-2 border-b border-border-dark">Specifications</h2>
        <table class="w-full text-sm">
          <tbody>
            {p.specs.map((spec) => (
              <tr class="border-b border-border-dark">
                <td class="py-2 px-3 font-medium text-text-secondary bg-[#0F172A]">{spec.label}</td>
                <td class="py-2 px-3 text-text-muted">{spec.value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

    <!-- Overview -->
    <div class="mb-8">
      <h2 class="text-xl font-bold text-text-primary mb-4 pb-2 border-b border-border-dark">Overview</h2>
      <p class="text-text-muted leading-relaxed mb-4">
        The {p.name} is a leading {p.category.toLowerCase()} for handheld gaming setups. 
        With its {p.tags[0].toLowerCase()} and optimized design, it delivers an exceptional experience.
      </p>
      <h3 class="text-lg font-semibold text-text-secondary mb-3">Key Features</h3>
      <ul class="list-disc pl-5 space-y-1 text-text-muted">
        <li>Designed for handheld gaming consoles and accessories</li>
        <li>High-quality construction for durability and comfort</li>
        <li>Compatible with Steam Deck, ROG Ally, and other handhelds</li>
        <li>Great value at ${p.price}</li>
        <li>Rated {p.rating}/5.0 by the community</li>
      </ul>
    </div>

    <!-- Where to Buy -->
    <div class="mb-8">
      <h2 class="text-xl font-bold text-text-primary mb-4 pb-2 border-b border-border-dark">Where to Buy</h2>
      <p class="text-text-muted mb-4">Find the best deals for the {p.name}:</p>
      <div class="flex flex-wrap gap-2">
        {brandLink && (
          <a href={brandLink} target="_blank" rel="noopener noreferrer" class="inline-block px-5 py-2.5 bg-accent-purple text-white font-semibold text-sm hover:bg-accent-purple-hover transition-colors">
            {brandKey} Store
          </a>
        )}
        <a href={`https://www.amazon.com/s?k=${p.name.replace(/ /g, "+")}`} target="_blank" rel="noopener noreferrer" class="inline-block px-5 py-2.5 bg-accent-purple text-white font-semibold text-sm hover:bg-accent-purple-hover transition-colors">
          Buy on Amazon
        </a>
      </div>
    </div>
  </div>
</Layout>
