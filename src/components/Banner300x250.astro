<!-- Banner 300x250 -->
<div id="ad-bn-slot" class="ad-bn-slot"></div>

<script is:inline>
  (function() {
    var slot = document.getElementById('ad-bn-slot');
    if (!slot) return;
    var key = '5a80ce7f116946c73b77837f2eb661f6';
    var url = 'https://www.highperformanceformat.com/' + key + '/invoke.js';

    var iframe = document.createElement('iframe');
    iframe.style.width = '300px';
    iframe.style.height = '250px';
    iframe.style.border = '0';
    iframe.scrolling = 'no';
    iframe.frameBorder = '0';

    slot.innerHTML = '';
    slot.appendChild(iframe);

    var d = iframe.contentWindow.document;
    d.open();
    d.write('<html><head><style>*{margin:0;padding:0}</style></head><body>');
    d.write("<script>atOptions = {'key':'" + key + "','format':'iframe','height':250,'width':300,'params':{}};<\/script>");
    d.write("<script src='" + url + "'><\/script>");
    d.write('</body></html>');
    d.close();
  })();
</script>

<style>
  .ad-bn-slot { background:#0f172a; border:1px solid #1e293b; min-height:250px; display:flex; align-items:center; justify-content:center; padding:4px; margin:1rem 0; }
</style>
